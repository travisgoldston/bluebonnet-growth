{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.bluebonnetgrowth.com" }],
      "destination": "https://bluebonnetgrowth.com/$1",
      "permanent": true
    },
    { "source": "/seo-company-:city", "destination": "/", "permanent": true },
    { "source": "/seo-company-:city.html", "destination": "/", "permanent": true }
  ]
}